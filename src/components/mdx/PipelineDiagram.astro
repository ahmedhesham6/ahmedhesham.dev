---
---

<div class="diagram my-10">
  <div class="box">
    <span class="label">Langfuse</span>
    <span class="sub">Sessions</span>
  </div>

  <div class="connector">
    <div class="line"><div class="pulse" style="--d:0s" /></div>
    <span class="tag">Extract</span>
  </div>

  <div class="box">
    <span class="label">S3 Staging</span>
    <span class="sub">JSON + Manifests</span>
  </div>

  <div class="connector">
    <div class="line"><div class="pulse" style="--d:0.5s" /></div>
    <span class="tag">Load</span>
  </div>

  <div class="box box-ov">
    <span class="label">OpenViking</span>
    <span class="sub">L0 / L1 / L2</span>
  </div>

  <div class="fan">
    <div class="fan-col">
      <div class="line line-fan"><div class="pulse" style="--d:0.8s" /></div>
      <div class="box box-agent"><span class="label">Quality Agent</span></div>
    </div>
    <div class="fan-col">
      <div class="line line-fan"><div class="pulse" style="--d:1.1s" /></div>
      <div class="box box-agent"><span class="label">Usage Agent</span></div>
    </div>
    <div class="fan-col">
      <div class="line line-fan"><div class="pulse" style="--d:1.4s" /></div>
      <div class="box box-agent"><span class="label">Gaps Agent</span></div>
    </div>
  </div>

  <div class="sched">
    <span class="sched-dot" />
    <span class="sched-text">Dagu — daily at 4am UTC</span>
  </div>
</div>

<style>
  .diagram {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .box {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.15rem;
    padding: 0.8rem 2rem;
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    border-radius: var(--radius-md);
  }

  .box-ov {
    width: 100%;
    max-width: 440px;
    padding: 1rem 2rem;
  }

  .box-ov .label {
    font-size: 1rem;
  }

  .box-ov .sub {
    font-size: 0.7rem;
  }

  .box-agent {
    padding: 0.6rem 1.2rem;
  }

  .box-agent .label {
    font-size: 0.78rem;
  }

  .label {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 0.85rem;
    color: var(--color-text);
    white-space: nowrap;
  }

  .sub {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--color-text-tertiary);
  }

  .connector {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    height: 28px;
  }

  .line {
    width: 1.5px;
    height: 100%;
    background: var(--color-border);
    position: relative;
    overflow: hidden;
  }

  .line-fan {
    height: 24px;
  }

  .tag {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: var(--color-text-tertiary);
  }

  @keyframes drop {
    0% { top: -12px; opacity: 0; }
    10% { opacity: 1; }
    90% { opacity: 1; }
    100% { top: 100%; opacity: 0; }
  }

  .pulse {
    position: absolute;
    left: -0.25px;
    top: -12px;
    width: 2px;
    height: 12px;
    background: var(--color-accent-400);
    box-shadow: 0 0 8px var(--color-accent-400);
    animation: drop 1.4s ease-in-out infinite;
    animation-delay: var(--d);
  }

  .fan {
    display: flex;
    width: 100%;
    max-width: 440px;
    justify-content: space-between;
    padding: 0 0.5rem;
  }

  .fan-col {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .sched {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 1rem;
  }

  .sched-dot {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--color-accent-400);
    animation: blink 2s ease-in-out infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 0.3; }
    50% { opacity: 1; }
  }

  .sched-text {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--color-text-tertiary);
  }

  @media (prefers-reduced-motion: reduce) {
    .pulse, .sched-dot {
      animation: none;
      opacity: 1;
    }
  }
</style>
